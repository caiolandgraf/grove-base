# ========================
# Database (PostgreSQL)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=grove_user
DB_PASSWORD=grove_password
DB_NAME=grove_db
DB_SSLMODE=disable

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# OpenTelemetry
# ========================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=grove-base
OTEL_EXPLOERER_OTLP_ENDPOINT=localhost:4318
OTEL_TRACE_SAMPLE_RATIO=1.0
METRICS_ENABLED=true

# ========================
# Application
# ========================
SERVER_ADDR=:8080
ENVIRONMENT=development
BASE_URL=http://localhost:8080
APP_NAME="Grove Base"
APP_DESC="A production-ready Grove boilerplate"
APP_OGDC="A production-ready Grove boilerplate"
CORS_ALLOWED_ORIGINS=http://localhost
COOKIE_DOMAIN=

# ========================
# Logging
# ========================
# Supported levels: debug, info, warn, error
LOG_LEVEL=info
# File for Promtail/Loki (set empty to disable file logging)
LOG_FILE=.grove/logs/app.log

# ========================
# Rate limiting
# ========================
RATE_LIMIT_LIMIT=5
RATE_LIMIT_WINDOW_SEC=30
RATE_LIMIT_WRITE_LIMIT=3
RATE_LIMIT_WRITE_WINDOW_SEC=60
# Comma-separated IPs or CIDRs allowed to set X-Forwarded-For (e.g. 127.0.0.1,10.0.0.0/8)
RATE_LIMIT_TRUSTED_PROXIES=
