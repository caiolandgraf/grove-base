# ========================
# Database (PostgreSQL)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=grove_user
DB_PASSWORD=grove_password
DB_NAME=grove_db
DB_SSLMODE=disable

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# OpenTelemetry
# ========================
OTEL_SERVICE_NAME=grove-app
OTEL_EXPLOERER_OTLP_ENDPOINT=localhost:4318

# ========================
# Application
# ========================
BASE_URL=http://localhost:8080
APP_NAME="Grove APP"
APP_DESC="A production-ready Grove boilerplate"
APP_OGDC="A production-ready Grove boilerplate"

# ========================
# Logging
# ========================
# Supported levels: debug, info, warn, error
LOG_LEVEL=info
