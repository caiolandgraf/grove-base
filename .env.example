# ========================
# Database (PostgreSQL)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mcs_dctfweb_sender
DB_SSLMODE=disable

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# OpenTelemetry
# ========================
OTEL_SERVICE_NAME=go-project-base
OTEL_EXPLOERER_OTLP_ENDPOINT=localhost:4318

# ========================
# Application
# ========================
BASE_URL=http://localhost:8080
APP_NAME="Go Project Base"
APP_DESC="A production-ready Go REST API boilerplate"
APP_OGDC="A production-ready Go REST API boilerplate"

# ========================
# Logging
# ========================
# Supported levels: debug, info, warn, error
LOG_LEVEL=info
