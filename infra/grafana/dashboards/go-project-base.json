      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "title": "Request Rate by Status Code & Route",
      "description": "HTTP requests per second grouped by status code and route. Use Grafana Explore → Jaeger for full trace search.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service=\"go-project-base\"}[1m])) by (http_response_status_code, http_route, http_request_method)",
          "legendFormat": "{{http_response_status_code}} {{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "lineWidth": 2,
            "fillOpacity": 15,
