      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 31,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "title": "Request Rate by Route",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service=\"go-project-base\"}[1m])) by (http_route, http_request_method)",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Route" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          },
          {
            "matcher": { "id": "byName", "options": "Method" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "yellow", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "id": 32,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "p95", "desc": true }]
      },
      "title": "Latency by Route (p50 / p95 / p99)",
      "type": "table",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{service=\"go-project-base\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p50",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service=\"go-project-base\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p95",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{service=\"go-project-base\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "p99",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "le": true },
            "renameByName": {
              "http_route": "Route",
              "http_request_method": "Method",
              "Value #A": "p50",
              "Value #B": "p95",
              "Value #C": "p99"
            }
          }
        }
      ]
    }
